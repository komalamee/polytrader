# PolyTrader runtime settings (example only; no secrets)

POLYTRADER_ACCOUNT_LABEL=polytrader
POLYTRADER_PROFILE_ADDRESS=0x0000000000000000000000000000000000000000
POLYTRADER_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

POLYTRADER_MAX_TRADE_USD=10
POLYTRADER_MAX_DAILY_LOSS_USD=30
POLYTRADER_KILL_SWITCH=hard stop at -$30 daily realised pnl

POLYTRADER_ARM_LIVE=false
POLYTRADER_EXECUTION_ENGINE_ENABLED=false

# Optional explicit CLOB creds (worker derives when omitted)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

POLYTRADER_PRIVATE_KEY=
POLYTRADER_FUNDER_ADDRESS=0x0000000000000000000000000000000000000000

POLYTRADER_CYCLE_SECONDS=45
POLYTRADER_CLOB_HOST=https://clob.polymarket.com
POLYTRADER_GAMMA_HOST=https://gamma-api.polymarket.com
POLYTRADER_CHAIN_ID=137
POLYTRADER_SIGNATURE_TYPE=0

POLYTRADER_MAX_OPEN_POSITIONS=12
POLYTRADER_MARKET_COOLDOWN_SECONDS=7200
POLYTRADER_MIN_EDGE=0.015
POLYTRADER_MIN_CONFIDENCE=0.62
POLYTRADER_EDGE_SCALE=0.05
POLYTRADER_MARKET_LIMIT=80
POLYTRADER_LIVE_START_EQUITY_USD=1000

POLYTRADER_DATA_DIR=.data
POLYTRADER_STATE_PATH=.data/polytrader-live-state.json
POLYTRADER_EVENTS_PATH=.data/polytrader-live-events.jsonl
